depends: [
  "dune" {>= "3.16"}
  "ocaml" {>= "4.14"}
  "llm-core" {= version}
  "lwt"
  "lwt_ppx" {>= "2.0.0"}
  "cohttp-lwt-unix"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}

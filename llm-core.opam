# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Core interfaces for LLM provider API clients"
description:
  "Runtime-agnostic, HTTP-client-agnostic core interfaces for building LLM provider API clients (Anthropic, OpenAI, xAI Grok, ...). Provides a CPS-style HTTP-client interface that can be implemented with any async runtime (Lwt, Eio, synchronous) and any HTTP library, plus provider-neutral message / tool-use / usage types so the same agentic loop works across providers."
maintainer: ["sabine@makerprism.com"]
authors: ["Sabine Schmaltz"]
license: "MIT"
homepage: "https://github.com/makerprism/ocaml-llm-sdk"
doc: "https://github.com/makerprism/ocaml-llm-sdk"
bug-reports: "https://github.com/makerprism/ocaml-llm-sdk/issues"
depends: [
  "dune" {>= "3.16"}
  "ocaml" {>= "4.14"}
  "yojson"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/makerprism/ocaml-llm-sdk.git"
